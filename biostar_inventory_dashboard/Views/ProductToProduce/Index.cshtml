@{
    ViewData["Title"] = "Product to Produce";
}

@section Styles {
    <link rel="stylesheet" href="~/css/producttoproduce.css" asp-append-version="true" />
}

<div class="container-fluid ptp-page">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <small class="text-muted">Production &gt; Product to Produce</small>
            <h2 class="fw-bold mt-2 mb-0">Product to Produce Request</h2>
            <small class="text-muted">Create production request from planning shortages or manual items.</small>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-primary" id="btnLoadShortages">
                Load Planning Shortages
            </button>
            <button class="btn btn-outline-secondary" id="btnAddManualLine">
                Add Product
            </button>
            <button class="btn btn-success" id="btnSavePtp">
                Save Request
            </button>
            <button class="btn btn-outline-dark" id="btnPrintPtp" disabled>
                Print
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Requested Date</label>
                    <input type="date" class="form-control" id="requestedDate" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Created By</label>
                    <input type="text" class="form-control" id="createdBy" value="@ViewBag.CurrentUser" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Status</label>
                    <input type="text" class="form-control" value="PENDING" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Remarks</label>
                    <input type="text" class="form-control" id="headerRemarks" placeholder="Optional remarks" />
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="min-width:260px;">Product</th>
                            <th>Suggested Qty</th>
                            <th style="min-width:150px;">Qty Input</th>
                            <th style="min-width:150px;">UOM Type</th>
                            <th style="min-width:180px;">Equivalent Base Qty</th>
                            <th>Delivery Date</th>
                            <th style="min-width:220px;">Remarks</th>
                            <th>Source</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody id="ptpLinesBody">
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">No products added yet.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="printArea" class="d-none"></div>

@section Scripts {
    <script src="~/js/producttoproduce.js" asp-append-version="true"></script>
}