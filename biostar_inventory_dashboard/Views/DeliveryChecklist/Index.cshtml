@{
    ViewData["Title"] = "Delivery Checklist";
}

@section Styles {
    @* <link rel="stylesheet" href="~/css/dispatch.css" /> *@
}




<div class="dispatch-page">

    
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <small class="text-muted">Dashboard > Dispatch</small>
            <h2 class="fw-bold mb-0">Delivery Checklist</h2>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" type="button" onclick="loadChecklistList()">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>

            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createChecklistModal">
                <i class="bi bi-plus-circle"></i> Create Checklist
            </button>
        </div>
    </div>

    <div class="row mb-3">

        <div class="col-md-2">
            <label>Date</label>
            <input type="date" id="filterDate" class="form-control">
        </div>

        <div class="col-md-2">
            <label>Status</label>
            <select id="filterStatus" class="form-select">
                <option value="">All</option>
                <option value="READY">Ready</option>
                <option value="LOADING">Loading</option>
                <option value="PARTIAL">Partial</option>
                <option value="COMPLETED">Completed</option>
            </select>
        </div>

        <div class="col-md-2">
            <label>Truck</label>
            <input type="text" id="filterTruck" class="form-control">
        </div>

        <div class="col-md-3">
            <label>Search</label>
            <input type="text" id="filterSearch" class="form-control" placeholder="Checklist No">
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-primary" onclick="applyFilters()">
                Apply
            </button>
            <button class="btn btn-outline-secondary" onclick="resetFilters()">
                Reset
            </button>
        </div>

    </div>

    <!-- TABLE -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Checklist No</th>
                            <th>Date</th>
                            <th>Route</th>
                            <th>Truck</th>
                            <th>Driver</th>
                            <th>Total Customers</th>
                            <th>Created By</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody id="checklistTableBody">
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                Loading...
                            </td>
                        </tr>
                    </tbody>

                </table>
            </div>

        </div>
    </div>
    

</div>

<!-- ============================= -->
<!-- CREATE CHECKLIST MODAL -->
<!-- ============================= -->

<div class="modal fade" id="createChecklistModal">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content rounded-4">

           
            <div class="modal-header">
                <div>
                    <h5 class="fw-bold mb-0">Create Delivery Checklist</h5>
                    <small class="text-muted">Select orders to include in this trip</small>
                </div>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- CHECKLIST INFO -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <label class="form-label">Delivery Date</label>
                        <input type="date" class="form-control" id="create_delivery_date">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Route</label>
                        <input type="text" class="form-control" id="create_route" placeholder="e.g Laguna">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Truck</label>
                        <input type="text" class="form-control" id="create_truck">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Driver</label>
                        <input type="text" class="form-control" id="create_driver">
                    </div>
                </div>

                <!-- ORDER TABLE -->
                <div class="table-responsive">
                    <table class="table table-sm align-middle">

                        <thead>
                            <tr>
                                <th><input type="checkbox" id="selectAllOrders"></th>
                                <th>Order No</th>
                                <th>Customer</th>
                                <th>Route</th>
                                <th>Product</th>
                                <th>Required</th>
                                <th>Allocated</th>
                                <th>Delivery Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody id="createChecklistTableBody">
                            <tr>
                                <td colspan="9" class="text-center text-muted py-3">
                                    Loading...
                                </td>
                            </tr>
                        </tbody>

                    </table>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-primary" onclick="submitCreateChecklist()">
                    Create Checklist
                </button>
            </div>

        </div>
    </div>
    

</div>

<!-- ============================= -->
<!-- VIEW CHECKLIST MODAL -->
<!-- ============================= -->

<div class="modal fade" id="viewChecklistModal">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content rounded-4">

         
            <div class="modal-header">
                <div>
                    <h5 class="fw-bold mb-0">Checklist Details</h5>
                    <small class="text-muted">Multi-customer delivery</small>
                </div>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- HEADER INFO -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <small class="text-muted">Checklist No</small>
                        <div class="fw-semibold" id="view_checklist_no"></div>
                    </div>
                    <div class="col-md-3">
                        <small class="text-muted">Route</small>
                        <div class="fw-semibold" id="view_route"></div>
                    </div>
                    <div class="col-md-3">
                        <small class="text-muted">Truck</small>
                        <div class="fw-semibold" id="view_truck"></div>
                    </div>
                    <div class="col-md-3">
                        <small class="text-muted">Driver</small>
                        <div class="fw-semibold" id="view_driver"></div>
                    </div>
                </div>

                <!-- DELIVERY LINES -->
                <div class="card border-0 bg-light rounded-4">
                    <div class="card-body">

                        <h6 class="fw-bold mb-3">Delivery Lines</h6>

                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Customer</th>
                                        <th>Product</th>
                                        <th>Lot No</th>
                                        <th>Mfg Date</th>
                                        <th>Expiry Date</th>
                                        <th>Qty</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>

                                <tbody id="viewChecklistLinesBody">
                                    <tr>
                                        <td colspan="7" class="text-center text-muted">No data</td>
                                    </tr>
                                </tbody>

                            </table>
                        </div>

                    </div>
                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-primary btn-confirm-loading" id="btnConfirmLoading">
                    Confirm Loading
                </button>

                <button class="btn btn-danger btn-delete-checklist" id="btnDeleteChecklist">
                    Delete
                </button>

                <button class="btn btn-warning" id="btnReopenChecklist">
                    Reopen
                </button>

              

                <button class="btn btn-secondary btn-print-checklist" id="btnPrintChecklist">
                    Print
                </button>

            </div>

        </div>
    </div>
  
   
</div>

@section Scripts {
    <script src="~/js/delivery-checklist.js" asp-append-version="true"></script>
}
