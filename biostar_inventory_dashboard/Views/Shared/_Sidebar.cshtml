@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}
<div class="col-md-2 sidebar p-4">
    <h4 class="fw-bold mb-4">Inventory</h4>

    <ul class="nav flex-column">

        <li class="nav-item mb-3">
            <a class="nav-link @(currentController == "Dashboard" ? "active fw-bold" : "")"
               href="/Dashboard">
                Dashboard
            </a>
        </li>

        <li class="nav-item mb-3">
            <a class="nav-link @(currentController == "Inventory" ? "active fw-bold" : "")"
               href="/Inventory">
                Inventory
            </a>
        </li>

        <li class="nav-item mb-3">
            <a class="nav-link @(currentController == "Transactions" ? "active fw-bold" : "")"
               href="/Transactions">
                Transactions
            </a>
        </li>

        <li class="nav-item mt-5">
            <a class="nav-link @(currentController == "Settings" ? "active fw-bold" : "")"
               href="/Settings">
                Settings
            </a>
        </li>

    </ul>
</div>