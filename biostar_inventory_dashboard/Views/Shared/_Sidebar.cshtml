@using System.Security.Claims
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

    var userRole = (
     User.FindFirst(ClaimTypes.Role)?.Value
     ?? User.FindFirst("role_name")?.Value
     ?? ""
 ).ToUpper();

    var isReceivingOpen = currentController == "ManualStockIn";
    var isPlanningOpen = currentController == "DailyOrder";
    var isProductionOpen =
        currentController == "ProductToProduce" ||
        currentController == "RawMaterialRequest" ||
        currentController == "ReceiveTransmittal";

    var isDispatchOpen = currentController == "DeliveryChecklist";
    var isInventoryOpen = currentController == "Inventory" || currentController == "Transactions";
    var isLogisticsOpen = currentController == "Logistics";
    var isReturnOpen = currentController == "Returns";
    var isReportOpen = currentController == "Reports";

    var isMasterDataOpen =
        currentController == "Product" ||
        currentController == "Categories" ||
        currentController == "Branch" ||
        currentController == "User" ||
        currentController == "Partner";
}

<div class="d-none d-md-block sidebar" id="desktopSidebar">
    <div class="sidebar-header mb-4">
        <h5 class="fw-bold mb-0"><span>BNPI SERVER</span></h5>
        <button type="button" class="sidebar-toggle-btn" id="sidebarToggleBtn">
            ☰
        </button>
    </div>

    <ul class="nav flex-column desktop-sidebar-menu">

@if (userRole == "PRODUCTION")
        {
            <!-- ONLY PRODUCTION MENU -->
            <li class="nav-item mb-2">
                <a class="nav-link @(currentController == "ProductToProduce" ? "active fw-bold" : "")"
                asp-controller="ProductToProduce"
                asp-action="Index">
                    <i class="bi bi-gear me-2"></i>
                    <span>Production</span>
                </a>
            </li>

            <li class="nav-item mb-2">
                <a class="nav-link d-flex justify-content-between align-items-center"
                   data-bs-toggle="collapse"
                   href="#inventoryMenu">
                    <div>
                        <i class="bi bi-box-seam me-2"></i>
                        <span>Inventory</span>
                    </div>
                    <span class="menu-arrow">▾</span>
                </a>

                <div class="collapse @(isInventoryOpen ? "show" : "")" id="inventoryMenu">
                    <ul class="nav flex-column ms-3 mt-1">
                        <li>
                            <a class="nav-link @(currentController == "Inventory" ? "active fw-bold" : "")" href="/Inventory">
                                <span>Stock Overview</span>
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(currentController == "Transactions" ? "active fw-bold" : "")" href="/Transactions">
                                <span>Transaction History</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </li>
        }
        else
        {
            <!-- Dashboard -->
            <li class="nav-item mb-2">
                <a class="nav-link @(currentController == "Dashboard" ? "active fw-bold" : "")" href="/Dashboard">
                    <i class="bi bi-speedometer2 me-2"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            <!-- Receiving -->
            <li class="nav-item mb-2">
                <a class="nav-link d-flex justify-content-between align-items-center"
                data-bs-toggle="collapse"
                href="#receivingMenu">
                    <div>
                        <i class="bi bi-box-arrow-in-down me-2"></i>
                        <span>Receiving</span>
                    </div>
                    <span class="menu-arrow">▾</span>
                </a>

                <div class="collapse @(isReceivingOpen ? "show" : "")" id="receivingMenu">
                    <ul class="nav flex-column ms-3 mt-1">
                        <li>
                            <a class="nav-link @(currentController == "ManualStockIn" ? "active fw-bold" : "")"
                            asp-controller="ManualStockIn"
                            asp-action="Index">
                                <span>Manual Stock IN</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Planning -->
            <li class="nav-item mb-2">
                <a class="nav-link d-flex justify-content-between align-items-center"
                data-bs-toggle="collapse"
                href="#planningMenu">
                    <div>
                        <i class="bi bi-calendar-check me-2"></i>
                        <span>Planning</span>
                    </div>
                    <span class="menu-arrow">▾</span>
                </a>

                <div class="collapse @(isPlanningOpen ? "show" : "")" id="planningMenu">
                    <ul class="nav flex-column ms-3 mt-1">
                        <li>
                            <a class="nav-link @(currentController == "DailyOrder" ? "active fw-bold" : "")" href="/DailyOrder">
                                <span>Daily Orders</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Production -->
            <li class="nav-item mb-2">
                <a class="nav-link d-flex justify-content-between align-items-center"
                data-bs-toggle="collapse"
                href="#productionMenu">
                    <div>
                        <i class="bi bi-gear me-2"></i>
                        <span>Production</span>
                    </div>
                    <span class="menu-arrow">▾</span>
                </a>

                <div class="collapse @(isProductionOpen ? "show" : "")" id="productionMenu">
                    <ul class="nav flex-column ms-3 mt-1">
                        <li>
                            <a class="nav-link @(currentController == "ProductToProduce" ? "active fw-bold" : "")"
                            asp-controller="ProductToProduce"
                            asp-action="Index">
                                <span>Product to Produce</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Dispatch -->
            <li class="nav-item mb-2">
                <a class="nav-link d-flex justify-content-between align-items-center"
                data-bs-toggle="collapse"
                href="#dispatchMenu">
                    <div>
                        <i class="bi bi-truck me-2"></i>
                        <span>Dispatch</span>
                    </div>
                    <span class="menu-arrow">▾</span>
                </a>

                <div class="collapse @(isDispatchOpen ? "show" : "")" id="dispatchMenu">
                    <ul class="nav flex-column ms-3 mt-1">
                        <li>
                            <a class="nav-link @(currentController == "DeliveryChecklist" ? "active fw-bold" : "")" href="/DeliveryChecklist">
                                <span>Delivery Checklist</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Inventory -->
            <li class="nav-item mb-2">
                <a class="nav-link d-flex justify-content-between align-items-center"
                data-bs-toggle="collapse"
                href="#inventoryMenu">
                    <div>
                        <i class="bi bi-box-seam me-2"></i>
                        <span>Inventory</span>
                    </div>
                    <span class="menu-arrow">▾</span>
                </a>

                <div class="collapse @(isInventoryOpen ? "show" : "")" id="inventoryMenu">
                    <ul class="nav flex-column ms-3 mt-1">
                        <li>
                            <a class="nav-link @(currentController == "Inventory" ? "active fw-bold" : "")" href="/Inventory">
                                <span>Stock Overview</span>
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(currentController == "Transactions" ? "active fw-bold" : "")" href="/Transactions">
                                <span>Transaction History</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Logistics -->
            @* <li class="nav-item mb-2">
            <a class="nav-link @(currentController == "Logistics" ? "active fw-bold" : "")" href="/Logistics">
                <i class="bi bi-map me-2"></i>
                <span>Logistics</span>
            </a>
        </li> *@

            <!-- Returns -->
            <li class="nav-item mb-2">
                <a class="nav-link d-flex justify-content-between align-items-center"
                data-bs-toggle="collapse"
                href="#returnMenu">
                    <div>
                        <i class="bi bi-arrow-counterclockwise me-2"></i>
                        <span>Return Product</span>
                    </div>
                    <span class="menu-arrow">▾</span>
                </a>

                <div class="collapse @(isReturnOpen ? "show" : "")" id="returnMenu">
                    <ul class="nav flex-column ms-3 mt-1">
                        <li>
                            <a class="nav-link @(currentController == "Returns" ? "active fw-bold" : "")"
                            asp-controller="Returns"
                            asp-action="Index">
                                <span>Returns</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Reports -->
            <li class="nav-item mb-2">
                <a class="nav-link d-flex justify-content-between align-items-center"
                data-bs-toggle="collapse"
                href="#reportMenu">
                    <div>
                        <i class="bi bi-bar-chart me-2"></i>
                        <span>Reports</span>
                    </div>
                    <span class="menu-arrow">▾</span>
                </a>

                <div class="collapse @(isReportOpen ? "show" : "")" id="reportMenu">
                    <ul class="nav flex-column ms-3 mt-1">
                        <li>
                            <a class="nav-link @(currentController == "Reports" ? "active fw-bold" : "")"
                            asp-controller="Reports"
                            asp-action="Index">
                                Reports
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Master Data -->
            @if (userRole == "ADMIN" || userRole == "STAFF")
            {
                <li class="nav-item mb-2">
                    <a class="nav-link d-flex justify-content-between align-items-center"
                    data-bs-toggle="collapse"
                    href="#masterMenu">
                        <div>
                            <i class="bi bi-database me-2"></i>
                            <span>Master Data</span>
                        </div>
                        <span class="menu-arrow">▾</span>
                    </a>

                    <div class="collapse @(isMasterDataOpen ? "show" : "")" id="masterMenu">
                        <ul class="nav flex-column ms-3 mt-1">
                            <li>
                                <a class="nav-link @(currentController == "Categories" ? "active fw-bold" : "")" href="/Categories">
                                    <span>Category</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(currentController == "Product" ? "active fw-bold" : "")" href="/Product">
                                    <span>Products</span>
                                </a>
                            </li>
                            <li>
                                <a class="nav-link @(currentController == "Branch" ? "active fw-bold" : "")" href="/Branch">
                                    <span>Branches</span>
                                </a>
                            </li>

                            @if (userRole == "ADMIN")
                            {
                                <li>
                                    <a class="nav-link @(currentController == "User" ? "active fw-bold" : "")" href="/User">
                                        <span>Users</span>
                                    </a>
                                </li>
                            }

                            <li>
                                <a class="nav-link @(currentController == "Partner" ? "active fw-bold" : "")" href="/Partner">
                                    <span>Partners</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>
            }
        }

    </ul>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const sidebar = document.getElementById("desktopSidebar");
        const toggleBtn = document.getElementById("sidebarToggleBtn");
        const mainContent = document.querySelector(".main-content");

        if (!sidebar || !toggleBtn || !mainContent) return;

        const savedState = localStorage.getItem("sidebarState");
        const activeMenu = localStorage.getItem("activeMenu");
        const savedScroll = localStorage.getItem("sidebarScrollTop");

        if (savedState === "collapsed") {
            sidebar.classList.add("collapsed");
            mainContent.classList.add("sidebar-collapsed");
        } else {
            sidebar.classList.remove("collapsed");
            mainContent.classList.remove("sidebar-collapsed");
        }

        if (activeMenu) {
            const menu = document.querySelector(activeMenu);
            if (menu) {
                menu.classList.add("show");
            }
        }

        if (savedScroll !== null) {
            setTimeout(() => {
                sidebar.scrollTop = parseInt(savedScroll, 10) || 0;
            }, 50);
        }

        toggleBtn.addEventListener("click", function (e) {
            e.preventDefault();
            e.stopPropagation();

            const isCollapsed = sidebar.classList.toggle("collapsed");
            mainContent.classList.toggle("sidebar-collapsed", isCollapsed);

            localStorage.setItem("sidebarState", isCollapsed ? "collapsed" : "expanded");
        });

        document.querySelectorAll('.sidebar .nav-link[data-bs-toggle="collapse"]').forEach(link => {
            link.addEventListener("click", function (e) {
                const target = this.getAttribute("href");
                if (!target) return;

                localStorage.setItem("activeMenu", target);
                localStorage.setItem("sidebarScrollTop", sidebar.scrollTop);

                if (sidebar.classList.contains("collapsed")) {
                    e.preventDefault();

                    sidebar.classList.remove("collapsed");
                    mainContent.classList.remove("sidebar-collapsed");
                    localStorage.setItem("sidebarState", "expanded");

                    setTimeout(() => {
                        const menu = document.querySelector(target);
                        if (menu) {
                            new bootstrap.Collapse(menu, {
                                toggle: true
                            });
                        }
                    }, 200);
                }
            });
        });

        document.querySelectorAll('.sidebar a[href]:not([data-bs-toggle="collapse"])').forEach(link => {
            link.addEventListener("click", function () {
                localStorage.setItem("sidebarScrollTop", sidebar.scrollTop);
            });
        });
    });
</script>