@{
    ViewData["Title"] = "Inventory List";
}

@section Styles {
    <link rel="stylesheet" href="~/css/inventory.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-4 page-header-row">
    <div>
        <small class="text-muted">Dashboard &gt; Inventory</small>
        <h2 class="fw-bold mt-2">Inventory List</h2>
    </div>

    <div class="action-buttons">
        <button class="btn btn-outline-primary">Import</button>
        <button class="btn btn-primary">Export</button>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 filter-card">
    <div class="card-body">
        <div class="row g-3 align-items-end">

            <div class="col-md-3">
                <label class="form-label fw-semibold">Company</label>
                <select class="form-select" id="companyFilter">
                    <option value="">All Company</option>
                    
                    <option value="Biostar Nutriproduct, Inc.">Biostar Nutriproduct, Inc.</option>
                    <option value="Animal Pharma Corp.">Animal Pharma Corp.</option>
                </select>
            </div>



            <div class="col-md-3">
                <label class="form-label fw-semibold">Warehouse</label>
                <select class="form-select" id="warehouseFilter">
                    <option value="">All Warehouses</option>
                    <option value="Main">Main</option>
                    <option value="Branch 1">Branch 1</option>
                    <option value="Branch 2">Branch 2</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">Order</label>
                <select class="form-select" id="orderFilter">
                    <option value="asc">Ascending</option>
                    <option value="desc">Descending</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">Filter Applied</label>
                <select class="form-select" id="filterApplied">
                    <option value="">None</option>
                    <option value="today">Today</option>
                    <option value="week">This Week</option>
                    <option value="month">This Month</option>
                </select>
            </div>

            <div class="col-md-3">
                <button class="btn btn-primary w-100" id="applyFilters">Apply Filters</button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <div class="table-scroll-box">
            <div class="table-responsive">
                <table class="table inventory-table align-middle">
                    <thead>
                        <tr>
                            <th>Lot No</th>
                            <th>Description</th>
                            <th>UOM</th>
                            <th>Qty</th>
                            <th>Stock Level</th>
                            <th>MFG. Date</th>
                            <th>EXP. Date</th>
                            <th>Warehouse</th>
                        </tr>
                    </thead>
                    <tbody id="inventoryTable">
                        <tr>
                            <td colspan="8" class="empty-state-cell">Loading inventory data...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/inventory.js" asp-append-version="true"></script>
}