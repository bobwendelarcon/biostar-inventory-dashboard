
@{
    ViewData["Title"] = "Daily Order Planning";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dailyorder.css" asp-append-version="true" />
}

<div class="dailyorder-page">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <small class="text-muted"> Planning &gt; Daily Order</small>
            <h2 class="fw-bold mt-2 mb-0">Daily Order Planning</h2>
            <small id="lastUpdatedText" class="text-muted"></small>
            @* <small class="text-muted">Plan customer orders, run FEFO allocation, and prepare dispatch.</small> *@
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-primary">
                <i class="bi bi-upload"></i> Import Excel
            </button>
            <button class="btn btn-outline-success">
                <i class="bi bi-download"></i> Export
            </button>
            <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#addOrderModal">
                <i class="bi bi-plus-circle"></i> Add Order
            </button>
        </div>
    </div>

    <!-- FILTER SECTION -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Class</label>
                    <select class="form-select" id="classFilter">
                        <option value="">All Class</option>
                        <option>ADM</option>
                        <option>ANDREA</option>
                        <option>ANIMAL P.</option>
                        <option>BATANGAS AP</option>
                        <option>BULACA AP</option>
                        <option>CDO ANIMAL P.</option>
                        <option>DAVAO AP</option>
                        <option>DGS LAYER</option>
                        <option>DGS PIGGERY</option>
                        <option>DGS ZOO</option>
                        <option>EDA</option>
                        <option>HOUSE</option>
                        <option>JDC</option>
                        <option>JKGM</option>
                        <option>LONGNO</option>
                        <option>MMJA MKTG</option>
                        <option>MYKIMAX</option>
                        <option>PIDV</option>
                        <option>QPLC</option>
                        <option>RANDY A</option>
                        <option>TDS</option>
                        <option>VISAYAS AP</option>
                        <option>WGS MKTG</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Year</label>
                    <select class="form-select" id="yearFilter">
                        <option value="">All Year</option>
                        <option selected>2026</option>
                        <option>2025</option>
                        <option>2024</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Month</label>
                    <select class="form-select" id="monthFilter">
                        <option value="" selected>All Month</option>
                        <option>January</option>
                        <option>February</option>
                        <option >March</option>
                        <option>April</option>
                        <option>May</option>
                        <option>June</option>
                        <option>July</option>
                        <option>August</option>
                        <option>September</option>
                        <option>October</option>
                        <option>November</option>
                        <option>December</option>
                    </select>
                </div>

                @* <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Status</label>
                    <select class="form-select" id="statusFilter">
                        <option value="">All Status</option>
                        @* <option>Draft</option> *@
                      @*  <option>For Allocation</option>
                        <option>Allocated</option>
                        <option>Partially Allocated</option>
                        <option>Ready for Dispatch</option>
                        <option>Partially Dispatched</option>
                        <option>COMPLETED</option>
                        <option>Overdue</option>
                        <option>Cancelled</option>
                    </select>
                </div> *@

            <div class="col-lg-2 col-md-6">
                <label class="form-label fw-semibold">Status</label>
                <select class="form-select" id="statusFilter">
                    <option value="ALL_EXCL_COMPLETED" selected>All Status (Excl. Completed)</option>
                    <option value="ALL">All Status</option>

                    <option value="FOR ALLOCATION">For Allocation</option>
                    <option value="ALLOCATED">Allocated</option>
                    <option value="PARTIALLY ALLOCATED">Partially Allocated</option>
                    <option value="READY FOR DISPATCH">Ready for Dispatch</option>
                    <option value="PARTIALLY DISPATCHED">Partially Dispatched</option>
                    <option value="COMPLETED">Completed</option>
                    <option value="OVERDUE">Overdue</option>
                    <option value="CANCELLED">Cancelled</option>
                </select>
            </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Search</label>
                    <input type="text" class="form-control" id="searchInput" placeholder="Customer / Product / DR#" />
                </div>

                <div class="col-lg-2 col-md-12">
                    <button class="btn btn-primary w-100" id="btnFilter">
                        <i class="bi bi-funnel"></i> Apply Filter
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- SUMMARY CARDS -->
    <div class="row g-3 mb-4">

        <div class="col">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Total Orders</div>
                    <div class="summary-value" id="summaryTotalOrders">0</div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">For Allocation</div>
                    <div class="summary-value text-warning" id="summaryForAllocation">0</div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Allocated</div>
                    <div class="summary-value text-success" id="summaryAllocated">0</div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Partially Allocated</div>
                    <div class="summary-value text-info" id="summaryPartial">0</div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Ready Dispatch</div>
                    <div class="summary-value text-primary" id="summaryReadyDispatch">0</div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card border-0 shadow-sm rounded-4 summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Partially Delivered</div>
                    <div class="summary-value text-warning" id="summaryPartiallyDelivered">0</div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Completed</div>
                    <div class="summary-value text-success" id="summaryCompleted">0</div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Overdue</div>
                    <div class="summary-value text-danger" id="summaryOverdue">0</div>
                </div>
            </div>
        </div>

    </div>

    <!-- TABLE SECTION -->
    <div class="card border-0 shadow-sm rounded-4">
        @* <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2"> *@
            @* <div> *@
                @* <h5 class="fw-bold mb-1">Daily Order List</h5>  *@
        @*         <small class="text-muted">Manage planning, FEFO allocation, and dispatch readiness</small>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-secondary btn-sm">Column Settings</button>
                <button class="btn btn-outline-dark btn-sm" id="btnRefreshOrders">Refresh</button>
            </div>
        </div> *@

        <div class="card-body p-0">
            <div class="table-responsive dailyorder-table-wrapper">
                <table class="table align-middle mb-0 dailyorder-table">
                    <thead>
                        <tr>
                            <th>Class</th>
                            <th>Year</th>
                            <th>Month</th>
                            <th>DO#</th>
                            <th>Customer</th>
                            <th>Product</th>

                            <!-- PLANNING -->
                            <th>Required Qty</th>
                            <th>Allocated Qty</th>
                            <th>Remaining</th>
                            <th>Dispatched Qty</th>
                            <th>Allocation</th>

                            <!-- DATES -->
                            <th>Date Ordered</th>
                            <th>Delivery Date</th>
                            <th>Date Delivered</th>
                            <th>Aging</th>

                            <!-- STATUS -->
                            <th>Status</th>

                            <th>Special Instructions</th>
                            <th>Created By</th>
                            <th >Actions</th>
                        </tr>
                    </thead>

                    <tbody id="dailyOrderTableBody">
                        <tr>
                            <td colspan="19" class="text-center text-muted py-4">Loading orders...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-0 px-4 py-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <small class="text-muted">Showing current results</small>

                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item disabled"><a class="page-link" href="#">Next</a></li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- VIEW ORDER MODAL -->
<div class="modal fade" id="viewOrderModal" tabindex="-1" aria-labelledby="viewOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title fw-bold" id="viewOrderModalLabel">Order Details</h5>
                    <small class="text-muted">Review order lines, FEFO allocation, and dispatch readiness</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <!-- ORDER HEADER -->
                <div class="row g-3 mb-4">
                    <div class="col-md-2">
                        <label class="form-label text-muted small mb-1">Order No</label>
                        <div class="fw-semibold" id="modalOrderNo">-</div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Customer</label>
                        <div class="fw-semibold" id="modalCustomerName">-</div>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label text-muted small mb-1">Delivery Date</label>
                        <div class="fw-semibold" id="modalDeliveryDate">-</div>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label text-muted small mb-1">Source Branch</label>
                        <div class="fw-semibold" id="modalSourceBranch">-</div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Status</label>
                        <div class="pt-1" id="modalStatusBadge">-</div>
                    </div>
                </div>

                <!-- ORDER LINE SUMMARY -->
                <div class="card border-0 bg-light rounded-4 mb-4">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">Order Line Summary</h6>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Required Qty</th>
                                        <th>Allocated Qty</th>
                                        @* <th>Available Before Allocation</th> *@
                                       <th> Available Stock (Excl. Reserved)</th>
                                        <th>Allocation Result</th>
                                    </tr>
                                </thead>
                                <tbody id="modalLineSummaryBody">
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">No order lines found.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- FEFO LOT BREAKDOWN -->
                <div class="card border-0 bg-light rounded-4">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">FEFO Lot Allocation</h6>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Branch</th>
                                        <th>Lot No</th>
                                        <th>MFG Date</th>
                                        <th>Expiry Date</th>
                                        <th>On Hand</th>
                                        <th>Reserved</th>
                                        <th>Available</th>
                                        <th>Allocated to Order</th>
                                        <th>Priority</th>
                                    </tr>
                                </thead>
                                <tbody id="modalLotAllocationBody">
                                    <tr>
                                        <td colspan="9" class="text-center text-muted">No FEFO allocation yet.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-info" id="btnModalRerunAllocation" type="button">Re-run FEFO Allocation</button>
                <button class="btn btn-outline-warning btn-edit-order" data-id="">
                    Edit Order
                </button>
                <button class="btn btn-primary" id="btnModalSendToDispatch" type="button">Send to Dispatch</button>
            </div>
        </div>
    </div>
</div>
<!-- EDIT ORDER MODAL -->
<div class="modal fade" id="editOrderModal" tabindex="-1" aria-labelledby="editOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title fw-bold" id="editOrderModalLabel">Edit Daily Order</h5>
                    <small class="text-muted">Update planning header details</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="editOrderId" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Customer</label>
                        <input type="text" class="form-control" id="editCustomerName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Class</label>
                        <select class="form-select" id="editClassName">
                            <option value="">Select Class</option>
                            <option>ADM</option>
                            <option>ANDREA</option>
                            <option>ANIMAL P.</option>
                            <option>BATANGAS AP</option>
                            <option>BULACA AP</option>
                            <option>CDO ANIMAL P.</option>
                            <option>DAVAO AP</option>
                            <option>DGS LAYER</option>
                            <option>DGS PIGGERY</option>
                            <option>DGS ZOO</option>
                            <option>EDA</option>
                            <option>HOUSE</option>
                            <option>JDC</option>
                            <option>JKGM</option>
                            <option>LONGNO</option>
                            <option>MMJA MKTG</option>
                            <option>MYKIMAX</option>
                            <option>PIDV</option>
                            <option>QPLC</option>
                            <option>RANDY A</option>
                            <option>TDS</option>
                            <option>VISAYAS AP</option>
                            <option>WGS MKTG</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Route</label>
                        <input type="text" class="form-control" id="editRouteName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Delivery Date</label>
                        <input type="date" class="form-control" id="editDeliveryDate" />
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Special Instructions</label>
                        <textarea class="form-control" id="editSpecialInstructions" rows="3"></textarea>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button>
                <button class="btn btn-primary" id="btnSaveEditOrder" type="button">Save Changes</button>
            </div>
        </div>
    </div>
</div>
<div id="floatingActionMenu" class="floating-action-menu d-none"></div>
<!-- ADD ORDER MODAL -->
<div class="modal fade" id="addOrderModal" tabindex="-1" aria-labelledby="addOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title fw-bold" id="addOrderModalLabel">Add Daily Order</h5>
                    <small class="text-muted">Create planning order and order lines</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <!-- HEADER -->
                <div class="row g-3 mb-4">
                    <div class="col-lg-2 col-md-6">
                        <label class="form-label fw-semibold">Class</label>
                        <select class="form-select" id="addClassName">
                            <option value="">All Class</option>
                            <option>ADM</option>
                            <option>ANDREA</option>
                            <option>ANIMAL P.</option>
                            <option>BATANGAS AP</option>
                            <option>BULACA AP</option>
                            <option>CDO ANIMAL P.</option>
                            <option>DAVAO AP</option>
                            <option>DGS LAYER</option>
                            <option>DGS PIGGERY</option>
                            <option>DGS ZOO</option>
                            <option>EDA</option>
                            <option>HOUSE</option>
                            <option>JDC</option>
                            <option>JKGM</option>
                            <option>LONGNO</option>
                            <option>MMJA MKTG</option>
                            <option>MYKIMAX</option>
                            <option>PIDV</option>
                            <option>QPLC</option>
                            <option>RANDY A</option>
                            <option>TDS</option>
                            <option>VISAYAS AP</option>
                            <option>WGS MKTG</option>
                        </select>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <label class="form-label fw-semibold">Customer</label>
                        <select class="form-select" id="addCustomerName">
                            <option value="">Loading customers...</option>
                        </select>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <label class="form-label fw-semibold">Source Branch</label>
                        <select class="form-select" id="addSourceBranch">
                            <option value="">Select source branch</option>
                        </select>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <label class="form-label fw-semibold">Route</label>
                        <input type="text" class="form-control" id="addRouteName" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Date Ordered</label>
                        <input type="date" class="form-control" id="addDateOrdered" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Delivery Date</label>
                        <input type="date" class="form-control" id="addDeliveryDate" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Created By</label>
                        <input type="text" class="form-control" id="addCreatedBy" value="@ViewBag.CurrentUser" readonly />
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Special Instructions</label>
                        <textarea class="form-control" id="addSpecialInstructions" rows="2"></textarea>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0">Order Lines</h6>
                </div>

                <!-- PRODUCT PICKER -->
                <div class="card border-0 bg-light rounded-4 mb-3">
                    <div class="card-body">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Category</label>
                                <select class="form-select" id="addLineCategory">
                                    <option value="">Select category</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Product</label>
                                <input type="text" class="form-control mb-2" id="addLineProductSearch" placeholder="Search product name" />
                                <select class="form-select" id="addLineProduct">
                                    <option value="">Select product</option>
                                </select>
                                <small class="text-muted d-block mt-2" id="addLineProductInfo"></small>
                            </div>

                            <div class="col-md-2">
                                <button type="button" class="btn btn-outline-primary w-100" id="btnAddSelectedProductLine">
                                    Add Line
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ORDER LINE TABLE -->
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th style="min-width: 220px;">Product</th>
                                <th style="min-width: 140px;">Qty Input</th>
                                <th style="min-width: 160px;">UOM Type</th>
                                <th style="min-width: 180px;">Equivalent Base Qty</th>
                                <th style="width: 90px;" class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="addOrderLinesBody">
                            <tr>
                                <td colspan="5" class="text-center text-muted">No order lines added yet.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
               
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal" type="button">Cancel</button>
                <button class="btn btn-primary" id="btnSaveAddOrder" type="button">Save Order</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dailyorder.js" asp-append-version="true"></script>
}