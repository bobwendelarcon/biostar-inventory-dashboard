@{
    ViewData["Title"] = "Daily Order";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dailyorder.css" asp-append-version="true" />
}

<div class="dailyorder-page">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <small class="text-muted">Dashboard &gt; Daily Order</small>
            <h2 class="fw-bold mt-2 mb-0">Daily Order</h2>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-primary">
                <i class="bi bi-upload"></i> Import Excel
            </button>
            <button class="btn btn-outline-success">
                <i class="bi bi-download"></i> Export
            </button>
            <button class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add Order
            </button>
        </div>
    </div>

    <!-- FILTER SECTION -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-semibold">Class</label>
                    <select class="form-select" id="classFilter">
                        <option value="">All Class</option>
                        <option>ANDREA</option>
                        <option>ADM</option>
                        <option>ANIMAL P.</option>
                        <option>BATANGAS AP</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Year</label>
                    <select class="form-select" id="yearFilter">
                        <option value="">All Year</option>
                        <option>2026</option>
                        <option>2025</option>
                        <option>2024</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Month</label>
                    <select class="form-select" id="monthFilter">
                        <option value="">All Month</option>
                        <option>January</option>
                        <option>February</option>
                        <option selected>March</option>
                        <option>April</option>
                        <option>May</option>
                        <option>June</option>
                        <option>July</option>
                        <option>August</option>
                        <option>September</option>
                        <option>October</option>
                        <option>November</option>
                        <option>December</option>
                    </select>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-semibold">Search</label>
                    <input type="text" class="form-control" id="searchInput" placeholder="Customer / Product / DR#" />
                </div>

                <div class="col-lg-2 col-md-12">
                    <button class="btn btn-primary w-100" id="btnFilter">
                        <i class="bi bi-funnel"></i> Apply Filter
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- SUMMARY CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card">
                <div class="card-body">
                    <div class="summary-label">Total Orders</div>
                    <div class="summary-value">125</div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card">
                <div class="card-body">
                    <div class="summary-label">Pending</div>
                    <div class="summary-value text-warning">42</div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card">
                <div class="card-body">
                    <div class="summary-label">Delivered</div>
                    <div class="summary-value text-success">68</div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card">
                <div class="card-body">
                    <div class="summary-label">Overdue</div>
                    <div class="summary-value text-danger">15</div>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLE SECTION -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h5 class="fw-bold mb-1">Daily Order List</h5>
                <small class="text-muted">Manage customer daily orders and delivery schedule</small>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-secondary btn-sm">Column Settings</button>
                <button class="btn btn-outline-dark btn-sm">Refresh</button>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive dailyorder-table-wrapper">
                <table class="table align-middle mb-0 dailyorder-table">
                    <thead>
                        <tr>
                            <th>Class</th>
                            <th>Year</th>
                            <th>Month</th>
                            <th>DR#/SI#</th>
                            <th>Customer</th>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Date Ordered</th>
                            <th>Delivery Date</th>
                            <th>Date Delivered</th>
                            <th>Status</th>
                            <th>Special Instructions</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>ANDREA</td>
                            <td>2026</td>
                            <td>March</td>
                            <td>DO-0001</td>
                            <td>JBT FARM RANCH CORP.</td>
                            <td>HOG MINERAL PREMIX</td>
                            <td>34 BAGS X 25KGS</td>
                            <td>March 12, 2026</td>
                            <td>March 13, 2026</td>
                            <td>March 13, 2026</td>
                            <td><span class="badge status-badge bg-success-subtle text-success">Delivered</span></td>
                            <td>SOLID</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary">View</button>
                                    <button class="btn btn-outline-warning">Edit</button>
                                    <button class="btn btn-outline-success">Done</button>
                                </div>
                            </td>
                        </tr>

                        <tr>
                            <td>ANDREA</td>
                            <td>2026</td>
                            <td>March</td>
                            <td>DO-0002</td>
                            <td>KURT JOHN</td>
                            <td>GBB FP POULTRY</td>
                            <td>110 BAGS</td>
                            <td>March 13, 2026</td>
                            <td>March 14, 2026</td>
                            <td>-</td>
                            <td><span class="badge status-badge bg-warning-subtle text-warning">Pending</span></td>
                            <td>SOLID</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary">View</button>
                                    <button class="btn btn-outline-warning">Edit</button>
                                    <button class="btn btn-outline-success">Done</button>
                                </div>
                            </td>
                        </tr>

                        <tr>
                            <td>ANDREA</td>
                            <td>2026</td>
                            <td>March</td>
                            <td>DO-0003</td>
                            <td>WS MARKETING</td>
                            <td>NATOX LIQUID</td>
                            <td>10 BOXES</td>
                            <td>March 13, 2026</td>
                            <td>March 13, 2026</td>
                            <td>-</td>
                            <td><span class="badge status-badge bg-danger-subtle text-danger">Overdue</span></td>
                            <td>SOLID</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary">View</button>
                                    <button class="btn btn-outline-warning">Edit</button>
                                    <button class="btn btn-outline-success">Done</button>
                                </div>
                            </td>
                        </tr>

                        <tr>
                            <td>ANDREA</td>
                            <td>2026</td>
                            <td>March</td>
                            <td>DO-0004</td>
                            <td>PROCHEM</td>
                            <td>AMOXI PRO 50 FP</td>
                            <td>6 BAGS</td>
                            <td>March 14, 2026</td>
                            <td>March 16, 2026</td>
                            <td>-</td>
                            <td><span class="badge status-badge bg-info-subtle text-info">For Delivery</span></td>
                            <td>Priority delivery</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary">View</button>
                                    <button class="btn btn-outline-warning">Edit</button>
                                    <button class="btn btn-outline-success">Done</button>
                                </div>
                            </td>
                        </tr>

                        <tr>
                            <td>ANDREA</td>
                            <td>2026</td>
                            <td>March</td>
                            <td>DO-0005</td>
                            <td>GEO FARM(KURT JOHN)</td>
                            <td>LAYER BASEMIX</td>
                            <td>8 BAGS</td>
                            <td>March 16, 2026</td>
                            <td>March 17, 2026</td>
                            <td>-</td>
                            <td><span class="badge status-badge bg-warning-subtle text-warning">Pending</span></td>
                            <td>-</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary">View</button>
                                    <button class="btn btn-outline-warning">Edit</button>
                                    <button class="btn btn-outline-success">Done</button>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-0 px-4 py-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <small class="text-muted">Showing 1 to 5 of 125 entries</small>

                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item"><a class="page-link" href="#">Next</a></li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>