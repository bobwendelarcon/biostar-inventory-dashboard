@{
    ViewData["Title"] = "Daily Order Planning";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dailyorder.css" asp-append-version="true" />
}

<div class="dailyorder-page">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <small class="text-muted">Dashboard &gt; Planning &gt; Daily Order</small>
            <h2 class="fw-bold mt-2 mb-0">Daily Order Planning</h2>
            <small class="text-muted">Plan customer orders, run FEFO allocation, and prepare dispatch.</small>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-primary">
                <i class="bi bi-upload"></i> Import Excel
            </button>
            <button class="btn btn-outline-success">
                <i class="bi bi-download"></i> Export
            </button>
            <button class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add Order
            </button>
        </div>
    </div>

    <!-- FILTER SECTION -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Class</label>
                    <select class="form-select" id="classFilter">
                        <option value="">All Class</option>
                        <option>ANDREA</option>
                        <option>ADM</option>
                        <option>ANIMAL P.</option>
                        <option>BATANGAS AP</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Year</label>
                    <select class="form-select" id="yearFilter">
                        <option value="">All Year</option>
                        <option selected>2026</option>
                        <option>2025</option>
                        <option>2024</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Month</label>
                    <select class="form-select" id="monthFilter">
                        <option value="">All Month</option>
                        <option>January</option>
                        <option>February</option>
                        <option selected>March</option>
                        <option>April</option>
                        <option>May</option>
                        <option>June</option>
                        <option>July</option>
                        <option>August</option>
                        <option>September</option>
                        <option>October</option>
                        <option>November</option>
                        <option>December</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Status</label>
                    <select class="form-select" id="statusFilter">
                        <option value="">All Status</option>
                        <option>Draft</option>
                        <option>For Allocation</option>
                        <option>Allocated</option>
                        <option>Partially Allocated</option>
                        <option>Ready for Dispatch</option>
                        <option>Partially Dispatched</option>
                        <option>Completed</option>
                        <option>Overdue</option>
                        <option>Cancelled</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-semibold">Search</label>
                    <input type="text" class="form-control" id="searchInput" placeholder="Customer / Product / DR#" />
                </div>

                <div class="col-lg-2 col-md-12">
                    <button class="btn btn-primary w-100" id="btnFilter">
                        <i class="bi bi-funnel"></i> Apply Filter
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- SUMMARY CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-lg-2 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Total Orders</div>
                    <div class="summary-value">125</div>
                </div>
            </div>
        </div>

        <div class="col-lg-2 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">For Allocation</div>
                    <div class="summary-value text-warning">24</div>
                </div>
            </div>
        </div>

        <div class="col-lg-2 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Allocated</div>
                    <div class="summary-value text-success">41</div>
                </div>
            </div>
        </div>

        <div class="col-lg-2 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Partial</div>
                    <div class="summary-value text-info">18</div>
                </div>
            </div>
        </div>

        <div class="col-lg-2 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Ready Dispatch</div>
                    <div class="summary-value text-primary">27</div>
                </div>
            </div>
        </div>

        <div class="col-lg-2 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 summary-card h-100">
                <div class="card-body">
                    <div class="summary-label">Overdue</div>
                    <div class="summary-value text-danger">15</div>
                </div>
            </div>
        </div>
    </div>

    <!-- TABLE SECTION -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h5 class="fw-bold mb-1">Daily Order List</h5>
                <small class="text-muted">Manage planning, FEFO allocation, and dispatch readiness</small>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-secondary btn-sm">Column Settings</button>
                <button class="btn btn-outline-dark btn-sm">Refresh</button>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive dailyorder-table-wrapper">
                <table class="table align-middle mb-0 dailyorder-table">


                    <thead>
                        <tr>
                            <th>Class</th>
                            <th>Year</th>
                            <th>Month</th>
                            <th>DR#/SI#</th>
                            <th>Customer</th>
                            <th>Product</th>

                            <!-- PLANNING -->
                            <th>Required Qty</th>
                            <th>Allocated Qty</th>
                            <th>Remaining</th>
                            <th>Allocation</th>

                            <!-- DATES -->
                            <th>Date Ordered</th>
                            <th>Delivery Date</th>
                            <th>Date Delivered</th>

                            <!-- STATUS -->
                            <th>Status</th>

                            <th>Special Instructions</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        <!-- FULLY COMPLETED -->
                        <tr>
                            <td>ANDREA</td>
                            <td>2026</td>
                            <td>March</td>
                            <td>DO-0001</td>
                            <td>ABCD FARM</td>
                            <td>FENBENDAZOLE FP</td>

                            <td>50 BAGS</td>
                            <td>50 BAGS</td>
                            <td>0</td>
                            <td><span class="badge bg-success-subtle text-success">Fully Allocated</span></td>

                            <td>March 12, 2026</td>
                            <td>March 13, 2026</td>
                            <td>March 13, 2026</td>

                            <td><span class="badge bg-success-subtle text-success">Completed</span></td>

                            <td>-</td>

                            <td class="text-center">
                                <div class="btn-group btn-group-sm flex-wrap">
                                    <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#viewOrderModal">
                                        View
                                    </button>
                                    <button class="btn btn-outline-warning">Edit</button>
                                </div>
                            </td>
                        </tr>

                        <!-- PARTIALLY ALLOCATED -->
                        <tr>
                            <td>ANDREA</td>
                            <td>2026</td>
                            <td>March</td>
                            <td>DO-0002</td>
                            <td>KURT JOHN</td>
                            <td>GBB FP POULTRY</td>

                            <td>100 BAGS</td>
                            <td>50 BAGS</td>
                            <td>50</td>
                            <td><span class="badge bg-warning-subtle text-warning">Partial</span></td>

                            <td>March 13, 2026</td>
                            <td>March 14, 2026</td>
                            <td>-</td>

                            <td><span class="badge bg-warning-subtle text-warning">Partially Allocated</span></td>

                            <td>SOLID</td>

                            <td class="text-center">
                                <div class="btn-group btn-group-sm flex-wrap">
                                    <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#viewOrderModal">
                                        View
                                    </button>
                                    <button class="btn btn-outline-warning">Edit</button>
                                    <button class="btn btn-outline-info">Allocate</button>
                                </div>
                            </td>
                        </tr>

                        <!-- READY FOR DISPATCH -->
                        <tr>
                            <td>ANDREA</td>
                            <td>2026</td>
                            <td>March</td>
                            <td>DO-0003</td>
                            <td>WS MARKETING</td>
                            <td>NATOX LIQUID</td>

                            <td>30 BOXES</td>
                            <td>30 BOXES</td>
                            <td>0</td>
                            <td><span class="badge bg-success-subtle text-success">Fully Allocated</span></td>

                            <td>March 13, 2026</td>
                            <td>March 14, 2026</td>
                            <td>-</td>

                            <td><span class="badge bg-primary-subtle text-primary">Ready for Dispatch</span></td>

                            <td>-</td>

                            <td class="text-center">
                                <div class="btn-group btn-group-sm flex-wrap">
                                    <button class="btn btn-outline-primary">View</button>
                                    <button class="btn btn-outline-warning">Edit</button>
                                    <button class="btn btn-outline-success">Dispatch</button>
                                </div>
                            </td>
                        </tr>

                        <!-- OVERDUE -->
                        <tr>
                            <td>ANDREA</td>
                            <td>2026</td>
                            <td>March</td>
                            <td>DO-0004</td>
                            <td>PROCHEM</td>
                            <td>AMOXI PRO 50 FP</td>

                            <td>20 BAGS</td>
                            <td>0</td>
                            <td>20</td>
                            <td><span class="badge bg-danger-subtle text-danger">Not Allocated</span></td>

                            <td>March 10, 2026</td>
                            <td>March 12, 2026</td>
                            <td>-</td>

                            <td><span class="badge bg-danger-subtle text-danger">Overdue</span></td>

                            <td>Priority</td>

                            <td class="text-center">
                                <div class="btn-group btn-group-sm flex-wrap">
                                    <button class="btn btn-outline-primary">View</button>
                                    <button class="btn btn-outline-warning">Edit</button>
                                    <button class="btn btn-outline-info">Allocate</button>
                                </div>
                            </td>
                        </tr>

                    </tbody>



                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-0 px-4 py-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <small class="text-muted">Showing 1 to 5 of 125 entries</small>

                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item"><a class="page-link" href="#">Next</a></li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- VIEW ORDER MODAL -->
<div class="modal fade" id="viewOrderModal" tabindex="-1" aria-labelledby="viewOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title fw-bold" id="viewOrderModalLabel">Order Details</h5>
                    <small class="text-muted">Review order lines, FEFO allocation, and dispatch readiness</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <!-- ORDER HEADER -->
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Order No</label>
                        <div class="fw-semibold">DO-0004</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Customer</label>
                        <div class="fw-semibold">PROCHEM</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Delivery Date</label>
                        <div class="fw-semibold">March 16, 2026</div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted small mb-1">Status</label>
                        <div><span class="badge bg-primary-subtle text-primary">Ready for Dispatch</span></div>
                    </div>
                </div>

                <!-- ORDER LINE SUMMARY -->
                <div class="card border-0 bg-light rounded-4 mb-4">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">Order Line Summary</h6>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Required Qty</th>
                                        <th>Allocated Qty</th>
                                        <th>Available Before Allocation</th>
                                        <th>Allocation Result</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>AMOXI PRO 50 FP</td>
                                        <td>6 BAGS</td>
                                        <td>6 BAGS</td>
                                        <td>20 BAGS</td>
                                        <td><span class="badge bg-success-subtle text-success">Fully Allocated</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- FEFO LOT BREAKDOWN -->
                <div class="card border-0 bg-light rounded-4">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">FEFO Lot Allocation</h6>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Lot No</th>
                                        <th>MFG Date</th>
                                        <th>Expiry Date</th>
                                        <th>On Hand</th>
                                        <th>Reserved</th>
                                        <th>Available</th>
                                        <th>Allocated to Order</th>
                                        <th>Priority</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>LOT-AP50-001</td>
                                        <td>January 10, 2026</td>
                                        <td>May 10, 2026</td>
                                        <td>10</td>
                                        <td>4</td>
                                        <td>6</td>
                                        <td>6</td>
                                        <td><span class="badge bg-success-subtle text-success">1st FEFO</span></td>
                                    </tr>
                                    <tr>
                                        <td>LOT-AP50-002</td>
                                        <td>January 20, 2026</td>
                                        <td>July 20, 2026</td>
                                        <td>14</td>
                                        <td>0</td>
                                        <td>14</td>
                                        <td>0</td>
                                        <td><span class="badge bg-light text-dark border">Next</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-info">Re-run FEFO Allocation</button>
                <button class="btn btn-outline-warning">Edit Order</button>
                <button class="btn btn-primary">Send to Dispatch</button>
            </div>
        </div>
    </div>
</div>