@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted">Dashboard &gt; Master Data &gt; Products</small>
        <h2 class="fw-bold mt-2 mb-0">Product Management</h2>
    </div>
    <button class="btn btn-primary rounded-3" id="btnAddProduct" data-bs-toggle="modal" data-bs-target="#productModal">
        + Add Product
    </button>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Search</label>
                <input type="text" class="form-control" id="searchProduct" placeholder="Search product..." />
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">Category</label>
                <select class="form-select" id="filterCategory">
                    <option value="">All Categories</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label fw-semibold">Status</label>
                <select class="form-select" id="filterStatus">
                    <option value="">All</option>
                    <option value="false">Active</option>
                    <option value="true">Inactive</option>
                </select>
            </div>

            <div class="col-md-1">
                <button class="btn btn-outline-secondary w-100" id="btnFilterProducts" type="button">Filter</button>
            </div>

            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" id="btnClearProducts" type="button">Clear</button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product ID</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>SKU</th>
                        <th>UOM</th>
                        <th>Pack UOM</th>
                        <th>Pack Qty</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="productTableBody">
                    <tr>
                        <td colspan="9" class="text-center text-muted">Loading products...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="productModalLabel">Add Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body pt-0">
                <input type="hidden" id="productFormMode" value="add" />
                <input type="hidden" id="originalProductId" />

                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Product Information</h6>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Product ID</label>
                            <input type="text" class="form-control" id="productId" placeholder="e.g. P001" />
                        </div>

                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Product Name</label>
                            <input type="text" class="form-control" id="productName" placeholder="Enter product name" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Category</label>
                            <select class="form-select" id="productCategory">
                                <option value="">Select category</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">SKU</label>
                            <input type="text" class="form-control" id="productSku" placeholder="Enter SKU" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Price</label>
                            <input type="number" step="0.01" class="form-control" id="productPrice" placeholder="0.00" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Stock Level</label>
                            <input type="number" step="0.01" class="form-control" id="productStockLevel" placeholder="0" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Status</label>
                            <select class="form-select" id="productStatus">
                                <option value="false">Active</option>
                                <option value="true">Inactive</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" id="productDescription" rows="3" placeholder="Enter product description"></textarea>
                        </div>
                    </div>
                </div>

                <div>
                    <h6 class="fw-bold mb-3">Unit Setup</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">UOM</label>
                            <input type="text" class="form-control" id="productUom" placeholder="e.g. kg, liter, pcs" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Pack UOM</label>
                            <input type="text" class="form-control" id="productPackUom" placeholder="e.g. box, sack, drum" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Pack Qty</label>
                            <input type="number" step="0.01" class="form-control" id="productPackQty" placeholder="e.g. 12" />
                        </div>

                        <div class="col-12">
                            <div class="alert alert-light border rounded-3 mb-0">
                                <small class="text-muted">
                                    Example: if UOM = <strong>kg</strong>, Pack UOM = <strong>box</strong>, and Pack Qty = <strong>12</strong>,
                                    then <strong>1 box = 12 kg</strong>.
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light rounded-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-3" id="btnSaveProduct">Save Product</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/products.js" asp-append-version="true"></script>
}