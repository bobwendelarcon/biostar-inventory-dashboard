@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted">Dashboard &gt; Master Data &gt; Products</small>
        <h2 class="fw-bold mt-2 mb-0">Product Management</h2>
    </div>
    <button class="btn btn-primary rounded-3" data-bs-toggle="modal" data-bs-target="#productModal">
        + Add Product
    </button>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Search</label>
                <input type="text" class="form-control" placeholder="Search product..." />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Category</label>
                <select class="form-select">
                    <option value="">All Categories</option>
                    <option>Raw Materials</option>
                    <option>Finished Goods</option>
                    <option>Packaging</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Status</label>
                <select class="form-select">
                    <option value="">All</option>
                    <option>Active</option>
                    <option>Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100">Filter</button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product ID</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>SKU</th>
                        <th>UOM</th>
                        <th>Pack UOM</th>
                        <th>Pack Qty</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>P001</td>
                        <td>Product A</td>
                        <td>Raw Materials</td>
                        <td>SKU-001</td>
                        <td>kg</td>
                        <td>box</td>
                        <td>12</td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1">Edit</button>
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                        </td>
                    </tr>
                    <tr>
                        <td>P002</td>
                        <td>Product B</td>
                        <td>Raw Materials</td>
                        <td>SKU-002</td>
                        <td>liter</td>
                        <td>drum</td>
                        <td>100</td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1">Edit</button>
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                        </td>
                    </tr>
                    <tr>
                        <td>P003</td>
                        <td>Product C</td>
                        <td>Finished Goods</td>
                        <td>SKU-003</td>
                        <td>kg</td>
                        <td>sack</td>
                        <td>10</td>
                        <td><span class="badge bg-secondary">Inactive</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1">Edit</button>
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="productModalLabel">Add Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-0">
                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Product Information</h6>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Product ID</label>
                            <input type="text" class="form-control" placeholder="e.g. P001" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Product Name</label>
                            <input type="text" class="form-control" placeholder="Enter product name" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Category</label>
                            <select class="form-select">
                                <option>Select category</option>
                                <option>Raw Materials</option>
                                <option>Finished Goods</option>
                                <option>Packaging</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">SKU</label>
                            <input type="text" class="form-control" placeholder="Enter SKU" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Status</label>
                            <select class="form-select">
                                <option>Active</option>
                                <option>Inactive</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" rows="3" placeholder="Enter product description"></textarea>
                        </div>
                    </div>
                </div>

                <div>
                    <h6 class="fw-bold mb-3">Unit Setup</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">UOM</label>
                            <input type="text" class="form-control" placeholder="e.g. kg, liter, pcs" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Pack UOM</label>
                            <input type="text" class="form-control" placeholder="e.g. box, sack, drum" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Pack Qty</label>
                            <input type="number" step="0.01" class="form-control" placeholder="e.g. 12" />
                        </div>
                        <div class="col-12">
                            <div class="alert alert-light border rounded-3 mb-0">
                                <small class="text-muted">
                                    Example: if UOM = <strong>kg</strong>, Pack UOM = <strong>box</strong>, and Pack Qty = <strong>12</strong>,
                                    then <strong>1 box = 12 kg</strong>.
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light rounded-3" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-3">Save Product</button>
            </div>
        </div>
    </div>
</div>