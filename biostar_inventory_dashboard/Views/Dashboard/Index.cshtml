                </div>
            </div>
        </div>
    </div> *@

    <!-- Partial Orders -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Partial Orders</h5>
                    <a href="/DailyOrder" class="btn btn-sm btn-outline-primary">View Orders</a>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Order No</th>
                                <th>Customer</th>
                                <th>Remaining</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="dashboardPartialOrdersBody">
                            @if (Model.PartialOrders != null && Model.PartialOrders.Any())
                            {
                                foreach (var item in Model.PartialOrders)
                                {
                                    <tr>
                                        <td>@item.OrderNo</td>
                                        <td>@item.CustomerName</td>
                                        <td>@item.RemainingQty</td>
                                        <td>
                                            <span class="badge bg-info text-dark">@item.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">No partial orders</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Inventory Alerts -->
    <!-- Inventory Alerts -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 dashboard-card-auto">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Inventory Alerts</h5>
                    <a href="/Inventory" class="btn btn-sm btn-outline-primary">Open Inventory</a>
                </div>

                <ul class="list-group list-group-flush" id="dashboardInventoryAlertsBody">
                    @if (Model.InventoryAlerts != null && Model.InventoryAlerts.Any())
                    {
                        foreach (var item in Model.InventoryAlerts)
                        {
                            var alertType = (item.AlertType ?? "").ToUpper();

                            var badgeClass = alertType == "OUT OF STOCK"
                            ? "bg-danger"
                            : "bg-warning text-dark";

                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span>
                                    @item.ProductName

                                    @if (alertType == "PLANNING SHORTAGE")
                                    {
                                        <small class="text-muted">
                                            @($"({item.AvailableQty} stock, {item.ReservedQty} reserved, {item.RequiredQty} required) → Short {item.ShortageQty} {item.Uom}")
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">
                                            (@item.Quantity @item.Uom available / Stock Level: @item.StockLevel @item.Uom)
                                        </small>
                                    }
                                </span>

                                <span class="badge @badgeClass">@item.AlertType</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item px-0 text-center text-muted">
                            No inventory alerts
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Recent Returns</h5>
                    <a href="/Return" class="btn btn-sm btn-outline-primary">View Return</a>
                </div>

                <ul class="list-group list-group-flush" id="dashboardRecentReturns">
                    @if (Model.RecentReturns != null && Model.RecentReturns.Any())
                    {
                        foreach (var item in Model.RecentReturns)
                        {
                            <li class="list-group-item px-0 py-3">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div>
                                        <div class="fw-semibold">@item.ReturnNo</div>
                                        <small class="text-muted d-block">
                                            @item.CustomerName
                                        </small>

                                        <div class="d-flex flex-wrap gap-1 mt-1">

                                            @if (!string.IsNullOrWhiteSpace(item.DrNo))
                                            {
                                                <span class="badge bg-secondary">DR: @item.DrNo</span>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(item.InvNo))
                                            {
                                                <span class="badge bg-dark">INV: @item.InvNo</span>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(item.PoNo))
                                            {
                                                <span class="badge bg-warning text-dark">PO: @item.PoNo</span>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(item.OrderNo))
                                            {
                                                <span class="badge bg-primary">DO: @item.OrderNo</span>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(item.ChecklistNo))
                                            {
                                                <span class="badge bg-info text-dark">DC: @item.ChecklistNo</span>
                                            }

                                        </div>

                                        <small class="text-muted d-block mt-1">
                                            Qty: @item.Quantity @item.Uom • @item.Reason
                                        </small>
                                    </div>
                                    @{
                                        var status = (item.Status ?? "").ToUpper();
                                        var cls = "bg-secondary";
                                        var display = item.Status; // default

                                        if (status == "QUARANTINE")
                                        {
                                            cls = "bg-info text-dark";
                                            display = "QUARANTINE";
                                        }
                                        else if (status == "PARTIALLY RELEASED")
                                        {
                                            cls = "bg-warning text-dark";
                                            display = "PARTIAL";
                                        }
                                        else if (status == "RELEASED FOR REPROCESS")
                                        {
                                            cls = "bg-success";
                                            display = "RELEASED"; // ✅ SHORT TEXT
                                        }
                                        else if (status == "CANCELLED")
                                        {
                                            cls = "bg-danger";
                                            display = "CANCELLED";
                                        }
                                    }

                                    <div class="text-end">
                                        <span class="badge @cls dashboard-return-status">@display</span>
                                    </div>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Recent Inventory Transactions</h5>
                    <a href="/Transactions" class="btn btn-sm btn-outline-primary">View History</a>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Customer</th>
                                <th>Reference</th>
                                <th>Lot No</th>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Type</th>
                            </tr>
                        </thead>
                        <tbody id="dashboardTransactionsBody">
                            @if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
                            {
                                @foreach (var item in Model.RecentTransactions)
                                {
                                    <tr>
                                        <td>@item.TransactionDate.ToString("yyyy-MM-dd HH:mm")</td>

                                        <!-- Customer -->
                                        <td class="fw-semibold">@item.CustomerName</td>

                                        <!-- Reference (Improved UI) -->
                                        <td>
                                            <div class="d-flex flex-wrap gap-1">
                                                @if (!string.IsNullOrWhiteSpace(item.DrNo))
                                                {
                                                    <span class="badge bg-secondary">DR: @item.DrNo</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(item.InvNo))
                                                {
                                                    <span class="badge bg-dark">INV: @item.InvNo</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(item.PoNo))
                                                {
                                                    <span class="badge bg-warning text-dark">PO: @item.PoNo</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(item.OrderNo))
                                                {
                                                    <span class="badge bg-primary">DO: @item.OrderNo</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(item.ChecklistNo))
                                                {
                                                    <span class="badge bg-info text-dark">DC: @item.ChecklistNo</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(item.LotNo))
                                            {
                                                <small class="text-muted">@item.LotNo</small>
                                            }
                                        </td>
                                        <!-- Product -->
                                        <td>@item.ProductName</td>

                                        <!-- Quantity -->
                                        <td>@item.Quantity @item.Uom</td>

                                        <!-- Type -->
                                        <td>
                                            <span class="badge @(item.Type == "OUT" ? "bg-danger" : "bg-success")">
                                                @item.Type
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <!-- Recent Returns -->
   

</div>
@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}