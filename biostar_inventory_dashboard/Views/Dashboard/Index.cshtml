@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Overview of planning, dispatch, logistics, inventory, and returns";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted">Home / Dashboard</small>
        <h2 class="fw-bold mt-2">Dashboard</h2>
    </div>
    <div>
        <button class="btn btn-outline-primary me-2">Refresh</button>
        <button class="btn btn-primary">Export Summary</button>
    </div>
</div>

<!-- SUMMARY CARDS -->
<div class="row g-3 mb-4">

    <div class="col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Daily Orders</small>
                <h3 class="fw-bold mt-2 mb-0">120</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Approval Queue</small>
                <h3 class="fw-bold mt-2 mb-0 text-warning">8</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Dispatched Today</small>
                <h3 class="fw-bold mt-2 mb-0 text-primary">15</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Partial Deliveries</small>
                <h3 class="fw-bold mt-2 mb-0 text-info">6</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Low Stock</small>
                <h3 class="fw-bold mt-2 mb-0 text-danger">12</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Returns Today</small>
                <h3 class="fw-bold mt-2 mb-0 text-secondary">3</h3>
            </div>
        </div>
    </div>

</div>

<div class="row g-4">

    <!-- Pending Approvals -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Pending Approvals</h5>
                    <a href="/Approval" class="btn btn-sm btn-outline-primary">View All</a>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Checklist No</th>
                                <th>Date</th>
                                <th>Truck</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>CHK-0001</td>
                                <td>2026-03-29</td>
                                <td>Truck 1</td>
                                <td><span class="badge bg-warning text-dark">For Approval</span></td>
                            </tr>
                            <tr>
                                <td>CHK-0002</td>
                                <td>2026-03-29</td>
                                <td>Truck 2</td>
                                <td><span class="badge bg-warning text-dark">For Approval</span></td>
                            </tr>
                            <tr>
                                <td>CHK-0003</td>
                                <td>2026-03-29</td>
                                <td>Truck 3</td>
                                <td><span class="badge bg-warning text-dark">For Approval</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Logistics Status -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Logistics Status</h5>
                    <a href="/Logistics" class="btn btn-sm btn-outline-primary">Track</a>
                </div>

                <div class="row text-center g-3">
                    <div class="col-6 col-md-3">
                        <div class="border rounded-3 p-3">
                            <small class="text-muted d-block">Approved</small>
                            <h4 class="fw-bold mb-0">5</h4>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="border rounded-3 p-3">
                            <small class="text-muted d-block">Dispatched</small>
                            <h4 class="fw-bold mb-0">7</h4>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="border rounded-3 p-3">
                            <small class="text-muted d-block">In Transit</small>
                            <h4 class="fw-bold mb-0">4</h4>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="border rounded-3 p-3">
                            <small class="text-muted d-block">Delivered</small>
                            <h4 class="fw-bold mb-0">11</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Partial Orders -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Partial Orders</h5>
                    <a href="/DailyOrder" class="btn btn-sm btn-outline-primary">View Orders</a>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Order No</th>
                                <th>Client</th>
                                <th>Remaining</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>DO-0001</td>
                                <td>Client A</td>
                                <td>12</td>
                                <td><span class="badge bg-info text-dark">Partial</span></td>
                            </tr>
                            <tr>
                                <td>DO-0002</td>
                                <td>Client B</td>
                                <td>7</td>
                                <td><span class="badge bg-info text-dark">Partial</span></td>
                            </tr>
                            <tr>
                                <td>DO-0003</td>
                                <td>Client C</td>
                                <td>20</td>
                                <td><span class="badge bg-info text-dark">Partial</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Inventory Alerts -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Inventory Alerts</h5>
                    <a href="/Inventory" class="btn btn-sm btn-outline-primary">Open Inventory</a>
                </div>

                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between px-0">
                        <span>Biovit 50kg</span>
                        <span class="badge bg-danger">Low Stock</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between px-0">
                        <span>Layer Basemix</span>
                        <span class="badge bg-danger">Out of Stock</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between px-0">
                        <span>Vitamin Premix</span>
                        <span class="badge bg-warning text-dark">Expiring Soon</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Recent Transactions</h5>
                    <a href="/Transactions" class="btn btn-sm btn-outline-primary">View History</a>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Reference</th>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Type</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>2026-03-29 08:30</td>
                                <td>CHK-0001</td>
                                <td>Biovit</td>
                                <td>20</td>
                                <td><span class="badge bg-danger">OUT</span></td>
                            </tr>
                            <tr>
                                <td>2026-03-29 09:15</td>
                                <td>RET-0001</td>
                                <td>Layer Basemix</td>
                                <td>5</td>
                                <td><span class="badge bg-success">RETURN IN</span></td>
                            </tr>
                            <tr>
                                <td>2026-03-29 09:40</td>
                                <td>CHK-0002</td>
                                <td>Mineral Mix</td>
                                <td>12</td>
                                <td><span class="badge bg-danger">OUT</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Returns -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Recent Returns</h5>
                    <a href="/Return" class="btn btn-sm btn-outline-primary">View Return</a>
                </div>

                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0">
                        <div class="fw-semibold">RET-0001</div>
                        <small class="text-muted">Client A - 5 pcs - Wrong Item</small>
                    </li>
                    <li class="list-group-item px-0">
                        <div class="fw-semibold">RET-0002</div>
                        <small class="text-muted">Client B - 2 pcs - Damaged</small>
                    </li>
                    <li class="list-group-item px-0">
                        <div class="fw-semibold">RET-0003</div>
                        <small class="text-muted">Client C - 3 pcs - Undelivered</small>
                    </li>
                </ul>
            </div>
        </div>
    </div>

</div>