@model biostar_inventory_dashboard.Models.DashboardDto
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Overview of planning, delivery checklist, dispatch, and inventory";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted">Home / Dashboard</small>
        <h2 class="fw-bold mt-2">Dashboard</h2>
    </div>
    <div>
        <button class="btn btn-outline-primary me-2" onclick="location.reload()">Refresh</button>
        <button class="btn btn-primary">Export Summary</button>
    </div>
</div>

<!-- SUMMARY CARDS -->
<!-- SUMMARY CARDS -->
<div class="row g-3 mb-4">

    <div class="col-md-4 col-lg">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Open Orders</small>
                <h3 id="openOrdersCount" class="fw-bold mt-2 mb-0">@Model.DailyOrders</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Ready for Checklist</small>
                <h3 id="readyForChecklistCount" class="fw-bold mt-2 mb-0 text-primary">@Model.ReadyForChecklist</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Checklist Queue</small>
                <h3 id="checklistQueueCount" class="fw-bold mt-2 mb-0 text-warning">@Model.ChecklistQueue</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Released Today</small>
                <h3 id="releasedTodayCount" class="fw-bold mt-2 mb-0 text-info">@Model.ReleasedToday</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Partial Delivery</small>
                <h3 id="partialDeliveryCount" class="fw-bold mt-2 mb-0 text-warning">@Model.PartialDispatch</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Low Stock</small>
                <h3 id="lowStockCount" class="fw-bold mt-2 mb-0 text-danger">@Model.LowStock</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <small class="text-muted">Completed Today</small>
                <h3 id="completedTodayCount" class="fw-bold mt-2 mb-0 text-success">@Model.CompletedOrders</h3>
            </div>
        </div>
    </div>

</div>
<div class="row g-4">

    <!-- Delivery Checklist -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Delivery Checklist</h5>
                    <a href="/DeliveryChecklist" class="btn btn-sm btn-outline-primary">View All</a>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Checklist No</th>
                                <th>Delivery Date</th>
                                <th>Truck</th>
                                <th>Status</th>
                            </tr>
                            </thead>
                        <tbody id="dashboardChecklistBody">
                            @if (Model.Checklist != null && Model.Checklist.Any())
                            {
                                foreach (var item in Model.Checklist)
                                {
                                    <tr>
                                        <td>@item.ChecklistNo</td>
                                        <td>@item.DeliveryDate?.ToString("yyyy-MM-dd")</td>
                                        <td>@item.TruckName</td>
                                        <td>
                                            <span class="badge bg-primary">@item.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">No checklist data</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Dispatch Status -->
